PORT="3000"

# --- Local: deixe DATABASE_URL vazio (usa pasta data/) — ver LOCAL.md
# --- Local + Docker: docker compose up -d
# DATABASE_URL="postgresql://botmanager:botmanager@localhost:5432/botmanager"

# --- Railway (conta nova): no painel do serviço, NÃO use este arquivo.
#     DATABASE_URL = referência ${{Postgres.DATABASE_URL}}
#     DATA_DIR = /data  (com volume montado em /data)
DATABASE_URL=""
DATABASE_PUBLIC_URL=""
DATA_DIR=""

# Gateway Laranjinha (alternativa ao Pix manual) — docs: https://laranjinha.digital/docs/api
LARANJINHA_API_BASE="https://laranjinha.digital/api"

# Opcional: o Railway ja sobe com um bot inicial se estes campos estiverem preenchidos.
